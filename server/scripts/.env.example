# ── SERVER ──
PORT=5000
NODE_ENV=development

# ── DATABASE ──
MONGO_URI=

# ── JWT ──
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── COOKIE ──
COOKIE_ACCESS_MAX_AGE=900000
COOKIE_REFRESH_MAX_AGE=604800000

# ── CLOUDINARY ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── EMAIL SERVICE SWITCH ──
EMAIL_SERVICE=google

# ── GOOGLE SMTP ──
GOOGLE_SMTP_USER=
GOOGLE_SMTP_PASS=

# ── BREVO SMTP ──
BREVO_SMTP_HOST=
BREVO_SMTP_PORT=
BREVO_SMTP_USER=
BREVO_SMTP_PASS=

# ── EMAIL IDENTITY ──
FROM_EMAIL=
FROM_NAME=GramDairy

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
